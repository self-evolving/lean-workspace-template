      "snippet": {
        "startLine": 45,
        "code": "/-- The sum of the first `n` odd numbers is `n²`. -/\ntheorem sumOdds_eq_sq (n : Nat) : sumOdds n = n * n := by\n  induction n with\n  | zero => rfl\n  | succ n ih =>\n    rw [sumOdds_succ, ih]\n    simp only [Nat.add_mul, Nat.mul_add, Nat.mul_one, Nat.one_mul]\n    omega"
